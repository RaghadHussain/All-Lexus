<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Lexues Cars</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header>
        <%- include('../partials/navbar') %>
            <h1>All <%= car.dealer?.dealerName || 'anything'%> Cars</h1>
    </header>
    <main>

        <section>
            <% let counter=1 %>
                <% for(let oneCar of car){ %>
                    <p>Car <%= counter %>: Lexus <%= oneCar.model %>
                    </p>
                    <a href="/lexusCar/<%= oneCar._id %>">View Lexues Details</a>
                    <% counter++ %>
                        <% } %>
        </section>
        <section>
            <form action="/lexusCar/new" method="get">
                <button>Add New Car</button>
            </form>
        </section>
    </main>
</body>

</html>